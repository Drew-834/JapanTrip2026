# Vite public config — copy to `.env` for local dev.
# For GitHub Actions, add the same as repository secrets (VITE_* names).

VITE_BASE=/

# Firebase web app config (Project settings → Your apps → SDK snippet → config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
# Must match the default bucket in Firebase (Project settings or Storage; e.g. your-project.firebasestorage.app). Same value in GitHub Actions secrets for Pages.
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — Google Analytics (measurementId from Firebase console)
# VITE_FIREBASE_MEASUREMENT_ID=
